# 1. Project Configuration
ENV=development
BASE_URL=http://localhost:8000
SECRET_KEY=generate_a_secure_random_secret_key_here

# 2. PostgreSQL Configuration
DB_PORT=5432
POSTGRES_DB=liturgybridge
POSTGRES_USER=liturgy_admin
POSTGRES_PASSWORD=choose_a_secure_password_for_db
DATABASE_URL=postgresql://liturgy_admin:choose_a_secure_password_for_db@localhost:5432/liturgybridge

# 3. Third-party integrations (SSO)
NEXTCLOUD_SSO_CLIENT_ID=
NEXTCLOUD_SSO_CLIENT_SECRET=
CHURCHTOOLS_API_KEY=

# 4. Translation & AI APIs
GEMINI_API_KEY=
DEEPL_API_KEY=
